{
  "name": "@cpdevtools/ts-dev-utilities-workspace",
  "version": "0.0.0-MAIN",
  "private": true,
  "description": "TypeScript development utilities — workspace root",
  "scripts": {
    "prepare": "wireit",
    "build": "devutil run build",
    "test": "devutil run test",
    "typecheck": "devutil run typecheck",
    "lint": "devutil run lint",
    "fix": "wireit",
    "format": "wireit",
    "check": "wireit",
    "clean": "wireit",
    "reset": "wireit"
  },
  "wireit": {
    "prepare": {
      "dependencies": [
        "prepare.husky"
      ]
    },
    "prepare.husky": {
      "command": "husky",
      "files": [
        ".husky/**"
      ],
      "output": []
    },
    "fix": {
      "dependencies": [
        "fix:syncpack",
        "fix:git-remove-tags"
      ]
    },
    "fix.deps": {
      "command": "devutil dep-versions fix .publish/deps.yml"
    },
    "fix.git-remove-tags": {
      "command": "git tag | xargs -r git tag -d"
    },
    "fix.syncpack": {
      "command": "syncpack fix-mismatches",
      "dependencies": [
        "fix.deps"
      ]
    },
    "format": {
      "dependencies": [
        "format.prettier"
      ]
    },
    "format.syncpack": {
      "command": "syncpack format"
    },
    "format.prettier": {
      "command": "prettier --write \"**/*.{ts,js,json,md,yml}\" --ignore-path .gitignore",
      "dependencies": [
        "format.syncpack"
      ]
    },
    "check": {
      "dependencies": [
        "check.deps",
        "check.syncpack"
      ]
    },
    "check.deps": {
      "command": "devutil dep-versions check .publish/deps.yml"
    },
    "check.syncpack": {
      "command": "syncpack list-mismatches"
    },
    "clean": {
      "dependencies": [
        "clean.git",
        "pnpm.install"
      ]
    },
    "clean.git": {
      "command": "git clean -dfX",
      "cache": false
    },
    "reset": {
      "dependencies": [
        "reset.git",
        "pnpm.install"
      ]
    },
    "reset.git": {
      "command": "git reset --hard",
      "cache": false
    },
    "pnpm.install": {
      "command": "pnpm install",
      "cache": false
    }
  },
  "keywords": [],
  "author": "CPDevTools",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cpdevtools/ts-dev-utilities.git"
  },
  "devDependencies": {
    "@cpdevtools/ts-dev-utilities-cli": "workspace:*",
    "@types/node": "^20.17.10",
    "@typescript-eslint/eslint-plugin": "^8.20.0",
    "@typescript-eslint/parser": "^8.20.0",
    "eslint": "^9.18.0",
    "husky": "^9.1.7",
    "prettier": "^3.4.2",
    "syncpack": "^13.0.0",
    "typescript": "^5.7.3",
    "wireit": "^0.14.13"
  },
  "engines": {
    "node": ">=24"
  }
}