{
  "name": "@cpdevtools/ts-dev-utilities-cli",
  "version": "0.0.0-MAIN",
  "description": "CLI tools for TypeScript development utilities (provides the devutil binary)",
  "bin": {
    "devutil": "./dist/bin.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "wireit",
    "typecheck": "wireit",
    "github.actions.build": "pnpm run build",
    "github.actions.pack": "pnpm pack"
  },
  "wireit": {
    "build": {
      "command": "tsup",
      "dependencies": ["../ts-dev-utilities:build"],
      "files": ["src/**/*.ts", "tsup.config.ts", "tsconfig.json"],
      "output": ["dist/**"]
    },
    "typecheck": {
      "command": "tsc --noEmit",
      "dependencies": ["../ts-dev-utilities:build"],
      "files": ["src/**/*.ts", "tsconfig.json"]
    }
  },
  "keywords": [
    "typescript",
    "cli",
    "devutil",
    "development"
  ],
  "author": "CPDevTools",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cpdevtools/ts-dev-utilities.git",
    "directory": "packages/cli"
  },
  "bugs": {
    "url": "https://github.com/cpdevtools/ts-dev-utilities/issues"
  },
  "homepage": "https://github.com/cpdevtools/ts-dev-utilities#readme",
  "dependencies": {
    "@cpdevtools/ts-dev-utilities": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^20.17.10",
    "tsup": "^8.3.5",
    "typescript": "^5.7.3"
  },
  "engines": {
    "node": ">=24"
  }
}
