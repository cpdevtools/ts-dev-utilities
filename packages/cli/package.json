{
  "name": "@cpdevtools/ts-dev-utilities-cli",
  "version": "0.0.0-MAIN",
  "description": "CLI tools for TypeScript development utilities (provides the devutil binary)",
  "bin": {
    "devutil": "./dist/bin.js"
  },
  "scripts": {
    "build": "wireit",
    "github.actions.build": "tsup",
    "github.actions.pack": "pnpm pack",
    "typecheck": "wireit"
  },
  "dependencies": {
    "@cpdevtools/ts-dev-utilities": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^20.17.10",
    "tsup": "^8.3.5",
    "typescript": "^5.7.3"
  },
  "keywords": [
    "cli",
    "development",
    "devutil",
    "typescript"
  ],
  "author": "CPDevTools",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cpdevtools/ts-dev-utilities.git",
    "directory": "packages/cli"
  },
  "bugs": "https://github.com/cpdevtools/ts-dev-utilities/issues",
  "homepage": "https://github.com/cpdevtools/ts-dev-utilities#readme",
  "engines": {
    "node": ">=24"
  },
  "files": [
    "dist"
  ],
  "wireit": {
    "build": {
      "command": "tsup",
      "dependencies": [
        "../ts-dev-utilities:build"
      ],
      "files": [
        "src/**/*.ts",
        "tsup.config.ts",
        "tsconfig.json"
      ],
      "output": [
        "dist/**"
      ]
    },
    "typecheck": {
      "command": "tsc --noEmit",
      "dependencies": [
        "../ts-dev-utilities:build"
      ],
      "files": [
        "src/**/*.ts",
        "tsconfig.json"
      ]
    }
  }
}
